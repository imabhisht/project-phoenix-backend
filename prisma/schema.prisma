generator client {
  provider = "prisma-client-js"
  output   = "../src/modules/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model tenants {
  id                 String   @id
  firebase_tenant_id String   @unique
  name               String
  description        String?
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @db.Timestamptz(6)
}
