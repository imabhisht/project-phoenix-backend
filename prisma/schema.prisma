generator client {
  provider = "prisma-client-js"
  output   = "../src/modules/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model tenants {
  id                 String   @id
  firebase_tenant_id String   @unique
  name               String
  description        String?
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @db.Timestamptz(6)
  users              users[]
}

model users {
  id              String   @id
  name            String
  organization_id String
  email           String
  username        String   @unique
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  role            String?
  tenants         tenants  @relation(fields: [organization_id], references: [id], onUpdate: NoAction)

  @@unique([organization_id, email], map: "users_org_email_unique")
}
